! Quickstep/GPW hexagonal-ice fragment calculation with ALMO EDA output.
! Derived from CP2K Made Simple snippets 071 and 073.
! Reference: The CP2K Program Package Made Simple, DOI: 10.1021/acs.jpcb.5c05851
! Additional ALMO workshop material:
! https://pc2.uni-paderborn.de/fileadmin/pc2/cp2k_workshop/almo.pdf

&GLOBAL
  PROJECT h2o-almo-eda
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD QS
  &DFT
    BASIS_SET_FILE_NAME GTH_BASIS_SETS
    POTENTIAL_FILE_NAME GTH_POTENTIALS
    &ALMO_SCF
      ALMO_ALGORITHM DIAG
      ALMO_SCF_GUESS MOLECULAR
      DELOCALIZE_METHOD XALMO_X
      EPS_FILTER 1.0E-8
      XALMO_R_CUTOFF_FACTOR 1.4
      &ALMO_OPTIMIZER_DIIS
        EPS_ERROR 5.0E-4
        MAX_ITER 10
        N_DIIS 5
      &END ALMO_OPTIMIZER_DIIS
      &ANALYSIS T
        FROZEN_MO_ENERGY_TERM SUBLATTICE
        &PRINT
          &ALMO_CTA
            FILENAME charge_terms
          &END ALMO_CTA
          &ALMO_EDA_CT
            FILENAME ct_energy_terms
          &END ALMO_EDA_CT
        &END PRINT
      &END ANALYSIS
      &XALMO_OPTIMIZER_PCG
        CONJUGATOR DAI_YUAN
        EPS_ERROR 5.0E-4
        LIN_SEARCH_EPS_ERROR 0.1
        LIN_SEARCH_STEP_SIZE_GUESS 0.5
        MAX_ITER 100
        MAX_ITER_OUTER_LOOP 0
      &END XALMO_OPTIMIZER_PCG
    &END ALMO_SCF
    &MGRID
      CUTOFF 200
      NGRIDS 4
    &END MGRID
    &QS
      ALMO_SCF T
      EPS_DEFAULT 1.0E-8
    &END QS
    &SCF
      EPS_SCF 1.0E-2
      SCF_GUESS ATOMIC
      &OT
        PRECONDITIONER FULL_ALL
      &END OT
    &END SCF
    &XC
      &XC_FUNCTIONAL BLYP
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      ABC 4.5198722000 7.8286483000 7.3588725000
      MULTIPLE_UNIT_CELL 1 1 1
    &END CELL
    &COORD
      O   2.2599361000  1.3047749776  0.9198590625 H2O
      H   3.0132482840  0.8698497241  0.6132391297 H2O
      H   2.2599361000  1.3047749776  1.8397181250 H2O
      O   2.2599361000  3.9143241500  0.0000000000 H2O
      H   3.0132482840  4.3492494035  0.3066199328 H2O
      H   2.2599361000  3.0444744259  0.3066199328 H2O
      O   0.0000000000  5.2190991276  0.9198590625 H2O
      H   0.7533121840  4.7841738741  0.6132391297 H2O
      H   0.0000000000  5.2190991276  1.8397181250 H2O
      O   2.2599361000  1.3047749776  3.6794362500 H2O
      H   1.5066239160  0.8698497241  3.9860561828 H2O
      H   2.2599361000  2.1746247017  3.9860561828 H2O
      O   0.0000000000  5.2190991276  3.6794362500 H2O
      H  -0.7533121840  4.7841738741  3.9860561828 H2O
      H   0.0000000000  6.0889488517  3.9860561828 H2O
    &END COORD
    &KIND O
      BASIS_SET DZVP-GTH
      POTENTIAL GTH-BLYP-q6
    &END KIND
    &KIND H
      BASIS_SET DZVP-GTH
      POTENTIAL GTH-BLYP-q1
    &END KIND
    &TOPOLOGY
      MULTIPLE_UNIT_CELL 1 1 1
    &END TOPOLOGY
  &END SUBSYS
&END FORCE_EVAL
