&FORCE_EVAL
  METHOD QMMM
  ...
  &QMMM
    ECOUPL Coulomb
    &CELL
      ABC 25.0 25.0 25.0
      PERIODIC XYZ
    &END CELL
    &QM_KIND C
      MM_INDEX 1..6
    &END QM_KIND
    &PERIODIC
      &MULTIPOLE OFF
      &END MULTIPOLE
    &END PERIODIC
 &END QMMM
&FORCE_EVAL
