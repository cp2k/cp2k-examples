&RI
  # Definition of the RI metric:
  RI_METRIC TRUNCATED
  CUTOFF_RADIUS 2.0
  # Optional but potentially
  # important keywords, here
  # with default values
  MEMORY_CUT 3
  EPS_FILTER 1.0E-9
&END RI
